#!/bin/bash

# {{ if or (eq .chezmoi.hostname "ml-server") (eq .chezmoi.hostname "ml-server-2") }}

{{- $openrgbProfile := "test" -}}
{{- if eq .chezmoi.hostname "ml-server-2" -}}
{{- $openrgbProfile = "ml-server-2" -}}
{{- end }}

# This comment is code! It calculates the hash of the profile. 
# If the profile changes, this script re-runs.
# Hash: {{ include (printf "dot_config/OpenRGB/%s.orp" $openrgbProfile) | sha256sum }}

if command -v openrgb >/dev/null 2>&1; then
    echo "OpenRGB profile detected. Applying '{{ $openrgbProfile }}' profile..."
    
    # Try to apply the profile. 
    # We use '|| true' so the script doesn't crash chezmoi if OpenRGB fails 
    # (e.g., if permissions aren't set up yet on a fresh install).
    /usr/bin/openrgb --profile {{ $openrgbProfile }} >/dev/null 2>&1 || echo "  (OpenRGB command failed - likely waiting on permissions/reboot)"
fi

# {{ end }}

#!/bin/bash
# SDDM ML4W Theme: Host-Aware Implementation
# chezmoi managed dependency hashes:
# main-qml={{ include "files/ml4w-sddm/Main.qml" | sha256sum }}
# lock-screen-qml={{ include "files/ml4w-sddm/components/LockScreen.qml" | sha256sum }}
# login-screen-qml={{ include "files/ml4w-sddm/components/LoginScreen.qml" | sha256sum }}
# input-qml={{ include "files/ml4w-sddm/components/Input.qml" | sha256sum }}
# avatar-qml={{ include "files/ml4w-sddm/components/Avatar.qml" | sha256sum }}
# spinner-qml={{ include "files/ml4w-sddm/components/Spinner.qml" | sha256sum }}
# icon-button-qml={{ include "files/ml4w-sddm/components/IconButton.qml" | sha256sum }}
# menu-area-qml={{ include "files/ml4w-sddm/components/MenuArea.qml" | sha256sum }}
# cvkeyboard-qml={{ include "files/ml4w-sddm/components/CVKeyboard.qml" | sha256sum }}
set -euo pipefail

TARGET_DIR="/etc/sddm.conf.d"
AUTOLOGIN_FILE="$TARGET_DIR/autologin.conf"
GENERAL_FILE="$TARGET_DIR/10-ml4w-general.conf"
THEME_FILE="$TARGET_DIR/10-ml4w-theme.conf"
THEME_DIR="/usr/share/sddm/themes/ml4w"
THEME_CONFIG="$THEME_DIR/configs/ml4w.conf"
THEME_VKB_STYLE="$THEME_DIR/components/QtQuick/VirtualKeyboard/Styles/vkeyboardStyle/style.qml"
THEME_BACKGROUNDS_DIR="$THEME_DIR/backgrounds"
TMP_DIR="${HOME}/.cache/ml4w-tmp/ml4w-sddm"
PRIMARY_COLOR_FILE="${HOME}/.config/ml4w/colors/primary"
KITTY_FOREGROUND_COLOR="#eaf2f1"
SOURCE_DIR="{{ .chezmoi.sourceDir }}"
OVERRIDE_DIR="$SOURCE_DIR/files/ml4w-sddm"
HOSTNAME="{{ .chezmoi.hostname }}"
AUTOLOGIN_USER="{{ .chezmoi.username }}"
AUTOLOGIN_SESSION="hyprland"
SDDM_BACKGROUND_NAME="Bonsai-Plant.png"
SDDM_BACKGROUND_SOURCE="$SOURCE_DIR/wallpapers/$SDDM_BACKGROUND_NAME"

echo "🚀 Configuring SDDM to use the ML4W theme for $HOSTNAME..."

install_ml4w_theme() {
    if [ -d "$THEME_DIR" ]; then
        echo "ℹ️ ML4W SDDM theme already present."
        return
    fi

    echo "📥 Installing ML4W SDDM theme..."
    rm -rf "$TMP_DIR"
    mkdir -p "$(dirname "$TMP_DIR")"
    git clone --depth 1 https://github.com/mylinuxforwork/ml4w-sddm "$TMP_DIR"
    sudo mkdir -p "$THEME_DIR"
    sudo cp -rf "$TMP_DIR"/. "$THEME_DIR"/
    rm -rf "$TMP_DIR"
}

apply_ml4w_overrides() {
    if [ ! -d "$OVERRIDE_DIR" ]; then
        return
    fi

    if [ -f "$OVERRIDE_DIR/Main.qml" ]; then
        sudo cp -f "$OVERRIDE_DIR/Main.qml" "$THEME_DIR/Main.qml"
    fi

    if [ -d "$OVERRIDE_DIR/components" ]; then
        sudo mkdir -p "$THEME_DIR/components"
        sudo cp -f "$OVERRIDE_DIR/components/"*.qml "$THEME_DIR/components/"
    fi
}

configure_sddm_background() {
    if [ ! -f "$SDDM_BACKGROUND_SOURCE" ]; then
        echo "⚠️ SDDM background source not found: $SDDM_BACKGROUND_SOURCE"
        return
    fi

    sudo mkdir -p "$THEME_BACKGROUNDS_DIR"
    sudo cp -f "$SDDM_BACKGROUND_SOURCE" "$THEME_BACKGROUNDS_DIR/$SDDM_BACKGROUND_NAME"

    if [ -f "$THEME_CONFIG" ]; then
        sudo sed -i "s/^background = .*/background = \"$SDDM_BACKGROUND_NAME\"/" "$THEME_CONFIG"
    fi
}

sudo mkdir -p "$TARGET_DIR"
install_ml4w_theme
apply_ml4w_overrides
configure_sddm_background

if [ -f "$PRIMARY_COLOR_FILE" ] && [ -f "$THEME_CONFIG" ]; then
    PRIMARY_COLOR=$(cat "$PRIMARY_COLOR_FILE")
    sudo sed -i "s/^primary-color = .*/primary-color = \"$PRIMARY_COLOR\"/" "$THEME_CONFIG"
    sudo sed -i "s/^color = .*/color = \"$PRIMARY_COLOR\"/" "$THEME_CONFIG"
    sudo sed -i "s/^content-color = .*/content-color = \"$KITTY_FOREGROUND_COLOR\"/" "$THEME_CONFIG"
    sudo sed -i "s/^active-content-color = .*/active-content-color = \"$KITTY_FOREGROUND_COLOR\"/" "$THEME_CONFIG"
    sudo sed -i "s/^normal-color = .*/normal-color = \"$PRIMARY_COLOR\"/" "$THEME_CONFIG"
    sudo sed -i "s/^warning-color = .*/warning-color = \"$PRIMARY_COLOR\"/" "$THEME_CONFIG"
    sudo sed -i "s/^error-color = .*/error-color = \"$PRIMARY_COLOR\"/" "$THEME_CONFIG"
    sudo sed -i "s/^key-content-color = .*/key-content-color = \"$KITTY_FOREGROUND_COLOR\"/" "$THEME_CONFIG"
    sudo sed -i "s/^selection-background-color = .*/selection-background-color = \"$PRIMARY_COLOR\"/" "$THEME_CONFIG"
    sudo sed -i "s/^selection-content-color = .*/selection-content-color = \"$KITTY_FOREGROUND_COLOR\"/" "$THEME_CONFIG"
    sudo sed -i '/^\[LoginScreen.VirtualKeyboard\]/,/^\[/{s/^background-color = .*/background-color = "#333751"/}' "$THEME_CONFIG"
    sudo sed -i '/^\[LoginScreen.VirtualKeyboard\]/,/^\[/{s/^background-opacity = .*/background-opacity = 0.0/}' "$THEME_CONFIG"
    sudo sed -i '/^\[LoginScreen.VirtualKeyboard\]/,/^\[/{s/^key-color = .*/key-color = "#333751"/}' "$THEME_CONFIG"
    sudo sed -i '/^\[LoginScreen.VirtualKeyboard\]/,/^\[/{s/^key-opacity = .*/key-opacity = 0.78/}' "$THEME_CONFIG"
    sudo sed -i '/^\[LoginScreen.VirtualKeyboard\]/,/^\[/{s/^key-active-background-color = .*/key-active-background-color = "#333751"/}' "$THEME_CONFIG"
    sudo sed -i '/^\[LoginScreen.VirtualKeyboard\]/,/^\[/{s/^key-active-opacity = .*/key-active-opacity = 0.92/}' "$THEME_CONFIG"
    sudo sed -i '/^\[LoginScreen.VirtualKeyboard\]/,/^\[/{s/^border-size = .*/border-size = 0/}' "$THEME_CONFIG"
fi

if [ -f "$THEME_VKB_STYLE" ]; then
    sudo sed -i 's/^    property color capsLockKeyAccentColor: .*/    property color capsLockKeyAccentColor: normalKeyBackgroundColor/' "$THEME_VKB_STYLE"
    sudo sed -i 's/^    property color modeKeyAccentColor: .*/    property color modeKeyAccentColor: normalKeyBackgroundColor/' "$THEME_VKB_STYLE"
    sudo sed -i 's/^    property color popupBackgroundColor: .*/    property color popupBackgroundColor: normalKeyBackgroundColor/' "$THEME_VKB_STYLE"
    sudo sed -i 's/^    property color popupBorderColor: .*/    property color popupBorderColor: highlightedKeyBackgroundColor/' "$THEME_VKB_STYLE"
    sudo sed -i 's/^    property color popupHighlightColor: .*/    property color popupHighlightColor: highlightedKeyBackgroundColor/' "$THEME_VKB_STYLE"
    sudo sed -i 's/^                    color: \"#566789\"/                    color: normalKeyBackgroundColor/' "$THEME_VKB_STYLE"
fi

GREETER_ENV="QML2_IMPORT_PATH=/usr/share/sddm/themes/ml4w/components/,QT_IM_MODULE=qtvirtualkeyboard"
{{ if eq .chezmoi.hostname "arch-surface" -}}
GREETER_ENV="QML2_IMPORT_PATH=/usr/share/sddm/themes/ml4w/components/,QT_IM_MODULE=qtvirtualkeyboard,QT_WAYLAND_SHELL_INTEGRATION=layer-shell"
{{ end -}}

TEMP_THEME=$(mktemp)
TEMP_GEN=$(mktemp)

cat <<EOF > "$TEMP_THEME"
[Theme]
Current=ml4w
EOF

cat <<EOF > "$TEMP_GEN"
[General]
InputMethod=qtvirtualkeyboard
GreeterEnvironment=$GREETER_ENV
{{ if eq .chezmoi.hostname "arch-surface" -}}
DisplayServer=wayland
{{ end -}}
EOF

if [ -f "$AUTOLOGIN_FILE" ]; then
    sudo rm -f "$AUTOLOGIN_FILE"
    echo "🔒 Removed SDDM autologin override."
fi

{{ if eq .chezmoi.hostname "ml-server" -}}
TEMP_AUTOLOGIN=$(mktemp)

cat <<EOF > "$TEMP_AUTOLOGIN"
[Autologin]
User=$AUTOLOGIN_USER
Session=$AUTOLOGIN_SESSION
Relogin=false
EOF

sudo mv "$TEMP_AUTOLOGIN" "$AUTOLOGIN_FILE"
sudo chown root:root "$AUTOLOGIN_FILE"
sudo chmod 644 "$AUTOLOGIN_FILE"
echo "🔓 Enabled SDDM autologin on startup for $HOSTNAME."
{{ end -}}

sudo mv "$TEMP_THEME" "$THEME_FILE"
sudo mv "$TEMP_GEN" "$GENERAL_FILE"
sudo chown root:root "$THEME_FILE" "$GENERAL_FILE"
sudo chmod 644 "$THEME_FILE" "$GENERAL_FILE"

echo "✅ SDDM configured to show the ML4W login screen."

#!/usr/bin/env bash

# Ensure the tracked chezmerge submodule is initialized before
# any hooks attempt to use upstream ML4W files.

SOURCE_DIR="{{ .chezmoi.sourceDir }}"
ML4W_REPO_DIR="$SOURCE_DIR/.chezmerge-upstream"

echo ":: CHEZMERGE SUBMODULE HOOK ::"

if [ ! -d "$SOURCE_DIR/.git" ]; then
    echo ":: ERROR: $SOURCE_DIR is not a git repository."
    exit 1
fi

if [ -d "$ML4W_REPO_DIR/.git" ] || [ -f "$ML4W_REPO_DIR/.git" ]; then
    echo ":: ML4W submodule already initialized. Skipping."
else
    echo ":: Initializing .chezmerge-upstream submodule..."
    git -C "$SOURCE_DIR" submodule update --init --recursive .chezmerge-upstream
    echo ":: Submodule ready."
fi

# The upstream repo should not report mode-only changes on systems with
# different executable bit behavior.
if [ -d "$ML4W_REPO_DIR/.git" ] || [ -f "$ML4W_REPO_DIR/.git" ]; then
    git -C "$ML4W_REPO_DIR" config core.filemode false
fi

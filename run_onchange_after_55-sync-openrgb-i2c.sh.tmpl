#!/usr/bin/env bash

# {{ if or (eq .chezmoi.hostname "ml-server") (eq .chezmoi.hostname "ml-server-2") }}

set -euo pipefail

info() { printf "\033[1;32m[INFO]\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m[WARN]\033[0m %s\n" "$*"; }

changed=0
reboot_required=0

detect_smbus_driver() {
    if grep -q 'AuthenticAMD' /proc/cpuinfo; then
        printf '%s\n' 'i2c-piix4'
    elif grep -q 'GenuineIntel' /proc/cpuinfo; then
        printf '%s\n' 'i2c-i801'
    else
        return 1
    fi
}

ensure_line_file() {
    local line=$1
    local path=$2

    if [ ! -f "$path" ] || ! sudo grep -Fxq "$line" "$path"; then
        printf '%s\n' "$line" | sudo tee "$path" >/dev/null
        changed=1
        info "Updated $path"
    fi
}

if ! pacman -Qi openrgb >/dev/null 2>&1; then
    info "Installing OpenRGB..."
    sudo pacman -S --needed --noconfirm openrgb
fi

if ! pacman -Qi i2c-tools >/dev/null 2>&1; then
    info "Installing i2c-tools..."
    sudo pacman -S --needed --noconfirm i2c-tools
fi

smbus_driver=$(detect_smbus_driver) || {
    warn "Could not determine SMBus driver for this system."
    smbus_driver=
}

ensure_line_file "i2c-dev" /etc/modules-load.d/i2c-dev.conf

if [ -n "${smbus_driver}" ]; then
    ensure_line_file "$smbus_driver" "/etc/modules-load.d/${smbus_driver}.conf"
fi

if ! lsmod | grep -q '^i2c_dev '; then
    sudo modprobe i2c-dev
    info "Loaded i2c-dev module immediately."
fi

if [ -n "${smbus_driver}" ]; then
    smbus_module=${smbus_driver//-/_}

    if ! lsmod | grep -q "^${smbus_module} "; then
        sudo modprobe "$smbus_driver"
        info "Loaded $smbus_driver module immediately."
    fi
fi

if [ ! -f /etc/udev/rules.d/99-i2c.rules ] || ! sudo grep -Fxq 'KERNEL=="i2c-[0-9]*", GROUP="i2c", MODE="0660"' /etc/udev/rules.d/99-i2c.rules; then
    printf '%s\n' 'KERNEL=="i2c-[0-9]*", GROUP="i2c", MODE="0660"' | sudo tee /etc/udev/rules.d/99-i2c.rules >/dev/null
    sudo udevadm control --reload
    sudo udevadm trigger
    changed=1
    info "Updated i2c udev permissions."
fi

getent group i2c >/dev/null || sudo groupadd i2c

if ! id -nG "$USER" | tr ' ' '\n' | grep -Fxq i2c; then
    sudo usermod -aG i2c "$USER"
    info "Added $USER to i2c group. Log out and back in to pick this up."
fi

limine_default=/etc/default/limine
target_param=acpi_enforce_resources=lax
regen_limine() {
    if command -v limine-mkinitcpio >/dev/null 2>&1; then
        sudo limine-mkinitcpio -P
    elif command -v limine-update >/dev/null 2>&1; then
        sudo limine-update
    else
        warn "Could not find limine-mkinitcpio or limine-update. Regenerate Limine manually."
        return 1
    fi
}

sync_limine_configs() {
    local source=/boot/limine.conf
    local target

    [ -f "$source" ] || return 0

    for target in /boot/EFI/arch-limine/limine.conf /boot/EFI/limine/limine.conf; do
        if [ -f "$target" ] && ! sudo cmp -s "$source" "$target"; then
            sudo install -m 0644 "$source" "$target"
            info "Synced $target from $source"
            changed=1
        fi
    done
}

if [ -f "$limine_default" ]; then
    if ! sudo grep -Eq "^[[:space:]]*KERNEL_CMDLINE\\[default\\]=" "$limine_default"; then
        current_args=$(sed 's/BOOT_IMAGE=[^ ]* //g; s/initrd=[^ ]* //g' /proc/cmdline)
        sudo tee -a "$limine_default" >/dev/null <<EOF
KERNEL_CMDLINE[default]="$current_args"
EOF
        changed=1
        reboot_required=1
        info "Added KERNEL_CMDLINE[default] to $limine_default"
    fi

    if ! sudo grep -Eq "^[[:space:]]*KERNEL_CMDLINE\\[default\\]=.*\\b$target_param\\b" "$limine_default"; then
        current_cmdline=$(sudo sed -n 's/^[[:space:]]*KERNEL_CMDLINE\\[default\\]=\"\\(.*\\)\"/\\1/p' "$limine_default" | tail -n 1)

        if [ -n "$current_cmdline" ]; then
            new_cmdline="$current_cmdline $target_param"
            escaped_current=$(printf '%s\n' "$current_cmdline" | sed 's/[.[\\*^$(){}?+|/]/\\\\&/g')
            escaped_new=$(printf '%s\n' "$new_cmdline" | sed 's/[&/]/\\\\&/g')
            sudo sed -i "s/^\\([[:space:]]*KERNEL_CMDLINE\\[default\\]=\"\\)$escaped_current\\(\"\\)/\\1$escaped_new\\2/" "$limine_default"
            changed=1
            reboot_required=1
            info "Appended $target_param to $limine_default"
            regen_limine || true
        else
            warn "Could not parse KERNEL_CMDLINE[default] from $limine_default"
        fi
    fi

    if sudo grep -Eq "^[[:space:]]*KERNEL_CMDLINE\\[default\\]=.*\\b$target_param\\b" "$limine_default" && ! grep -Eq "(^| )$target_param( |$)" /proc/cmdline; then
        info "Limine is configured for $target_param but the current boot is missing it."
        regen_limine || true
        reboot_required=1
    fi

    sync_limine_configs
else
    warn "$limine_default not found. Skipping bootloader sync."
fi

if [ "$changed" -eq 0 ]; then
    info "OpenRGB i2c configuration already up to date."
fi

if [ "$reboot_required" -eq 1 ]; then
    warn "Reboot required before OpenRGB can use SMBus devices."
fi

# {{ end }}

#!/usr/bin/env bash
# plymouth-theme={{ include "files/plymouth/arch-splash/arch-splash.plymouth" | sha256sum }}
# plymouth-watermark={{ include "files/plymouth/arch-splash/watermark.png" | sha256sum }}

set -euo pipefail

THEME_NAME="arch-splash"
SOURCE_DIR="{{ .chezmoi.sourceDir }}"
THEME_SOURCE_DIR="$SOURCE_DIR/files/plymouth/$THEME_NAME"
THEME_TARGET_DIR="/usr/share/plymouth/themes/$THEME_NAME"
SPINNER_THEME_DIR="/usr/share/plymouth/themes/spinner"
PLYMOUTH_CONF="/etc/plymouth/plymouthd.conf"
MKINITCPIO_CONF="/etc/mkinitcpio.conf"
DEFAULT_LIMINE_CONF="/etc/default/limine"
MASTER_LIMINE_CONF="/boot/limine.conf"
DEFAULT_MKINITCPIO_HOOKS="base udev autodetect microcode modconf kms keyboard keymap consolefont block plymouth filesystems btrfs-overlayfs fsck"

info() { printf "\033[1;32m[INFO]\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m[WARN]\033[0m %s\n" "$*"; }
err()  { printf "\033[1;31m[ERR ]\033[0m %s\n" "$*" >&2; }

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        err "Missing command: $1"
        exit 1
    }
}

update_hooks() {
    local hooks_line hooks trimmed tmp_file

    hooks_line="$(grep '^HOOKS=' "$MKINITCPIO_CONF" || true)"
    if [ -z "$hooks_line" ]; then
        hooks_line="HOOKS=($DEFAULT_MKINITCPIO_HOOKS)"
    fi

    trimmed="${hooks_line#HOOKS=(}"
    trimmed="${trimmed%)}"
    read -r -a hooks <<<"$trimmed"

    if [[ " ${hooks[*]} " != *" kms "* ]]; then
        local insert_at=-1
        local i
        for i in "${!hooks[@]}"; do
            if [ "${hooks[$i]}" = "keyboard" ] || [ "${hooks[$i]}" = "keymap" ] || [ "${hooks[$i]}" = "consolefont" ]; then
                insert_at=$i
                break
            fi
        done

        if [ "$insert_at" -ge 0 ]; then
            hooks=("${hooks[@]:0:$insert_at}" "kms" "${hooks[@]:$insert_at}")
        else
            hooks+=("kms")
        fi
    fi

    if [[ " ${hooks[*]} " != *" plymouth "* ]]; then
        local insert_at=-1
        local anchor
        local i
        for anchor in sd-encrypt encrypt filesystems; do
            for i in "${!hooks[@]}"; do
                if [ "${hooks[$i]}" = "$anchor" ]; then
                    insert_at=$i
                    break 2
                fi
            done
        done

        if [ "$insert_at" -ge 0 ]; then
            hooks=("${hooks[@]:0:$insert_at}" "plymouth" "${hooks[@]:$insert_at}")
        else
            hooks+=("plymouth")
        fi
    fi

    printf -v hooks_line 'HOOKS=(%s)' "${hooks[*]}"
    tmp_file="$(mktemp)"
    awk -v new_line="$hooks_line" '
        BEGIN { replaced = 0 }
        /^HOOKS=/ {
            print new_line
            replaced = 1
            next
        }
        { print }
        END {
            if (!replaced) {
                print new_line
            }
        }
    ' "$MKINITCPIO_CONF" >"$tmp_file"
    sudo install -m 0644 "$tmp_file" "$MKINITCPIO_CONF"
    rm -f "$tmp_file"
}

update_modules() {
    local modules_line modules trimmed tmp_file

    modules_line="$(grep '^MODULES=' "$MKINITCPIO_CONF" || true)"
    if [ -z "$modules_line" ]; then
        modules_line='MODULES=()'
    fi

    trimmed="${modules_line#MODULES=(}"
    trimmed="${trimmed%)}"
    read -r -a modules <<<"$trimmed"

    local module
    for module in nvidia nvidia_modeset nvidia_uvm nvidia_drm; do
        if [[ " ${modules[*]} " != *" $module "* ]]; then
            modules+=("$module")
        fi
    done

    printf -v modules_line 'MODULES=(%s)' "${modules[*]}"
    tmp_file="$(mktemp)"
    awk -v new_line="$modules_line" '
        BEGIN { replaced = 0 }
        /^MODULES=/ {
            print new_line
            replaced = 1
            next
        }
        { print }
        END {
            if (!replaced) {
                print new_line
            }
        }
    ' "$MKINITCPIO_CONF" >"$tmp_file"
    sudo install -m 0644 "$tmp_file" "$MKINITCPIO_CONF"
    rm -f "$tmp_file"
}

ensure_mkinitcpio_conf() {
    if [ -s "$MKINITCPIO_CONF" ] && grep -q '^HOOKS=' "$MKINITCPIO_CONF"; then
        return 0
    fi

    local tmp_file
    tmp_file="$(mktemp)"
    cat >"$tmp_file" <<EOF
# vim:set ft=sh:
MODULES=()
BINARIES=()
FILES=()
HOOKS=($DEFAULT_MKINITCPIO_HOOKS)
#COMPRESSION="zstd"
#COMPRESSION_OPTIONS=()
#MODULES_DECOMPRESS="no"
EOF
    sudo install -m 0644 "$tmp_file" "$MKINITCPIO_CONF"
    rm -f "$tmp_file"
}

ensure_limine_cmdline_flags() {
    [ -f "$DEFAULT_LIMINE_CONF" ] || return 0

    local tmp_file
    local has_nvidia="${1:-0}"
    tmp_file="$(mktemp)"

    sudo awk -v has_nvidia="$has_nvidia" '
        /^KERNEL_CMDLINE\[default\]=/ {
            line = $0
            sub(/^KERNEL_CMDLINE\[default\]="/, "", line)
            sub(/"$/, "", line)
            if (line !~ /(^|[[:space:]])quiet($|[[:space:]])/) {
                line = line " quiet"
            }
            if (line !~ /(^|[[:space:]])splash($|[[:space:]])/) {
                line = line " splash"
            }
            if (line !~ /(^|[[:space:]])loglevel=3($|[[:space:]])/) {
                line = line " loglevel=3"
            }
            if (line !~ /(^|[[:space:]])vt\.global_cursor_default=0($|[[:space:]])/) {
                line = line " vt.global_cursor_default=0"
            }
            if (has_nvidia == "1") {
                if (line !~ /(^|[[:space:]])nvidia-drm\.modeset=1($|[[:space:]])/) {
                    line = line " nvidia-drm.modeset=1"
                }
                if (line !~ /(^|[[:space:]])nvidia-drm\.fbdev=1($|[[:space:]])/) {
                    line = line " nvidia-drm.fbdev=1"
                }
            }
            gsub(/[[:space:]]+/, " ", line)
            sub(/^ /, "", line)
            sub(/ $/, "", line)
            print "KERNEL_CMDLINE[default]=\"" line "\""
            next
        }
        { print }
    ' "$DEFAULT_LIMINE_CONF" >"$tmp_file"

    sudo tee "$DEFAULT_LIMINE_CONF" >/dev/null <"$tmp_file"
    rm -f "$tmp_file"
}

preflight() {
    need_cmd sudo
    need_cmd install
    need_cmd awk
    need_cmd mkinitcpio

    if ! command -v plymouth-set-default-theme >/dev/null 2>&1; then
        warn "plymouth-set-default-theme not found. Skipping Plymouth setup until plymouth is installed."
        exit 0
    fi
}

has_nvidia() {
    modinfo nvidia_drm >/dev/null 2>&1
}

sync_limine_configs() {
    [ -f "$MASTER_LIMINE_CONF" ] || return 0

    local target
    for target in /boot/EFI/limine/limine.conf /boot/EFI/arch-limine/limine.conf; do
        if [ -d "$(dirname "$target")" ]; then
            sudo cp -f "$MASTER_LIMINE_CONF" "$target"
        fi
    done
}

preflight

if [ ! -d "$THEME_SOURCE_DIR" ]; then
    err "Missing theme source directory: $THEME_SOURCE_DIR"
    exit 1
fi

if [ ! -d "$SPINNER_THEME_DIR" ]; then
    err "Missing stock spinner theme at $SPINNER_THEME_DIR"
    exit 1
fi

info "Installing Plymouth theme: $THEME_NAME"
sudo install -d -m 0755 "$THEME_TARGET_DIR"
sudo cp -a "$SPINNER_THEME_DIR/." "$THEME_TARGET_DIR/"
sudo install -m 0644 "$THEME_SOURCE_DIR/$THEME_NAME.plymouth" "$THEME_TARGET_DIR/$THEME_NAME.plymouth"
sudo install -m 0644 "$THEME_SOURCE_DIR/watermark.png" "$THEME_TARGET_DIR/watermark.png"

info "Configuring Plymouth defaults"
sudo install -d -m 0755 "$(dirname "$PLYMOUTH_CONF")"
sudo tee "$PLYMOUTH_CONF" >/dev/null <<EOF
[Daemon]
Theme=$THEME_NAME
ShowDelay=0
EOF

info "Ensuring mkinitcpio config exists"
ensure_mkinitcpio_conf

info "Updating mkinitcpio hooks for Plymouth"
update_hooks

HAS_NVIDIA=0
if has_nvidia; then
    info "Configuring early NVIDIA KMS for Plymouth"
    update_modules
    HAS_NVIDIA=1
fi

info "Ensuring Limine kernel args include splash flags"
ensure_limine_cmdline_flags "$HAS_NVIDIA"

info "Selecting Plymouth theme and rebuilding initramfs"
sudo plymouth-set-default-theme "$THEME_NAME"

if command -v limine-mkinitcpio >/dev/null 2>&1; then
    sudo limine-mkinitcpio -P
elif command -v limine-update >/dev/null 2>&1; then
    sudo limine-update
else
    warn "Limine regeneration tool not found; Plymouth is configured but boot entries may need manual regeneration."
fi

sync_limine_configs

echo "✅ Plymouth configured for Limine."

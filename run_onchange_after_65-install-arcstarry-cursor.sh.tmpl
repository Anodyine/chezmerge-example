#!/usr/bin/env bash
set -eu

SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
ZIP_CANDIDATES=(
  "$SOURCE_DIR/.external_sources/dotfiles/setup/cursors/ArcStarry-cursors.zip"
  "$SOURCE_DIR/.chezmerge-upstream/setup/cursors/ArcStarry-cursors.zip"
)

ZIP_PATH=""
for candidate in "${ZIP_CANDIDATES[@]}"; do
  if [ -f "$candidate" ]; then
    ZIP_PATH="$candidate"
    break
  fi
done

if [ -z "$ZIP_PATH" ]; then
  echo "ArcStarry cursor zip not found; skipping install."
  exit 0
fi

mkdir -p "$HOME/.local/share/icons"
rm -rf "$HOME/.local/share/icons/ArcStarry-cursors"
unzip -qo "$ZIP_PATH" -d "$HOME/.local/share/icons"

mkdir -p "$HOME/.icons/default"
cat > "$HOME/.icons/default/index.theme" <<'EOF'
[Icon Theme]
Inherits=ArcStarry-cursors
EOF

echo "Installed ArcStarry-cursors from $ZIP_PATH"

#!/bin/bash
# Unified Boot & Snapshot Management - Robust & Host-Aware
set -euo pipefail

HOSTNAME="{{ .chezmoi.hostname }}"
SNAPPER_NUMBER_LIMIT="20"
SNAPPER_NUMBER_LIMIT_IMPORTANT="4"
echo "🚀 Starting Boot/Snapshot Config for $HOSTNAME..."

set_config_value() {
    local file="$1"
    local key="$2"
    local value="$3"
    local tmp_file

    tmp_file="$(mktemp)"
    sudo awk -v key="$key" -v value="$value" '
        BEGIN { replaced = 0 }
        $0 ~ ("^" key "=") {
            print key "=" value
            replaced = 1
            next
        }
        { print }
        END {
            if (!replaced) {
                print key "=" value
            }
        }
    ' "$file" > "$tmp_file"
    sudo install -m 0644 "$tmp_file" "$file"
    rm -f "$tmp_file"
}

# --- 1. Helper Detection & Auto-Install (RESTORED FROM OLD) ---
if command -v paru &> /dev/null; then
    AUR_HELPER="paru"
elif command -v yay &> /dev/null; then
    AUR_HELPER="yay"
else
    echo "📦 Installing yay (Dependency for AUR packages)..."
    sudo pacman -S --needed --noconfirm git base-devel
    TEMP_DIR=$(mktemp -d)
    git clone https://aur.archlinux.org/yay-bin.git "$TEMP_DIR/yay-bin"
    (cd "$TEMP_DIR/yay-bin" && makepkg -si --noconfirm)
    rm -rf "$TEMP_DIR"
    AUR_HELPER="yay"
fi

# --- 2. Install Packages ---
echo "📥 Installing snapshot and bootloader tools..."
$AUR_HELPER -S --needed --noconfirm \
    limine-snapper-sync snap-pac limine-mkinitcpio-hook

# --- 3. Snapper Initialization & Retention (RESTORED FROM OLD) ---
# This ensures Section 6/7 doesn't fail on a fresh install
if [ ! -f "/etc/snapper/configs/root" ]; then
    echo "📁 Snapper config missing. Initializing root config..."
    if mountpoint -q /.snapshots; then sudo umount /.snapshots; fi
    if [ -d "/.snapshots" ]; then sudo rm -rf /.snapshots; fi
    
    sudo snapper -c root create-config /
    
    # Standard cleanup for snapper-on-btrfs subvolumes
    sudo rm -rf /.snapshots
    sudo mkdir -p /.snapshots
    sudo mount -a || true
fi

echo "⚖️ Setting Snapper retention limits..."
sudo snapper -c root set-config \
    NUMBER_CLEANUP="yes" \
    NUMBER_LIMIT="$SNAPPER_NUMBER_LIMIT" \
    NUMBER_LIMIT_IMPORTANT="$SNAPPER_NUMBER_LIMIT_IMPORTANT" \
    EMPTY_PRE_POST_CLEANUP="yes" \
    TIMELINE_LIMIT_HOURLY="10" \
    TIMELINE_LIMIT_DAILY="21" \
    TIMELINE_LIMIT_WEEKLY="4" \
    TIMELINE_LIMIT_MONTHLY="2" \
    TIMELINE_LIMIT_YEARLY="0"

# --- 4. Central Configuration (Host-Aware) ---
DEFAULT_CONF="/etc/default/limine"
MASTER_CONF="/boot/limine.conf"
SYNC_CONF="/etc/limine-snapper-sync.conf"

sudo touch "$DEFAULT_CONF"

# Standard Global Vars
set_config_value "$DEFAULT_CONF" "LIMINE_CONFIG" "\"$MASTER_CONF\""
set_config_value "$DEFAULT_CONF" "ROOT_SNAPSHOTS_PATH" "\"/@snapshots\""
set_config_value "$DEFAULT_CONF" "MAX_SNAPSHOT_ENTRIES" "$SNAPPER_NUMBER_LIMIT"

if [ -f "$SYNC_CONF" ]; then
    sudo sed -E -i 's/^(COMMANDS_AFTER_SAVE="[^"]*")MAX_SNAPSHOT_ENTRIES=.*/\1/' "$SYNC_CONF"
    sudo sed -E -i 's/^(COMMANDS_AFTER_SAVE="[^"]*")ROOT_SNAPSHOTS_PATH=.*/\1/' "$SYNC_CONF"
    set_config_value "$SYNC_CONF" "MAX_SNAPSHOT_ENTRIES" "$SNAPPER_NUMBER_LIMIT"
    set_config_value "$SYNC_CONF" "ROOT_SNAPSHOTS_PATH" "\"/@snapshots\""
fi

# --- 5. Dynamic Kernel Parameter Extraction ---
# We grab everything currently in /proc/cmdline
CURRENT_CMDLINE=$(cat /proc/cmdline | sed -E 's/(BOOT_IMAGE|initrd|pci|pcie_aspm|intel_iommu|usb4_port_reset)[^ ]* ?//g')
for arg in quiet splash loglevel=3 vt.global_cursor_default=0; do
    if [[ " $CURRENT_CMDLINE " != *" $arg "* ]]; then
        CURRENT_CMDLINE="$CURRENT_CMDLINE $arg"
    fi
done
CURRENT_CMDLINE="$(echo "$CURRENT_CMDLINE" | xargs)"

# Clear existing line before re-adding
sudo sed -i '/^KERNEL_CMDLINE/d' "$DEFAULT_CONF"

{{ if eq .chezmoi.hostname "arch-surface" -}}
# --- 6. Surface-Specific Configuration ---
SURFACE_ARGS="pci=hpiosize=0"
echo "KERNEL_CMDLINE[default]=\"$CURRENT_CMDLINE $SURFACE_ARGS\"" | sudo tee -a "$DEFAULT_CONF" >/dev/null

SURFACE_VARS=(
    # Move linux-surface to the very beginning.
    # The "*" captures the standard 'linux' kernel as the next option.
    "BOOT_ORDER=\"linux-surface, *, *fallback, Snapshots\""
)

for var in "${SURFACE_VARS[@]}"; do
    key=$(echo $var | cut -d= -f1)
    sudo sed -i "/^$key=/d" "$DEFAULT_CONF"
    echo "$var" | sudo tee -a "$DEFAULT_CONF" > /dev/null
done

{{ else -}}
# --- 7. Standard Host Configuration ---
echo "KERNEL_CMDLINE[default]=\"$CURRENT_CMDLINE\"" | sudo tee -a "$DEFAULT_CONF" >/dev/null
sudo sed -i "/^TIMEOUT=/d" "$DEFAULT_CONF"
set_config_value "$DEFAULT_CONF" "TIMEOUT" "5"
{{ end -}}

# --- 7. Finalize & Sync ---
echo "⚙️ Regenerating bootloader and enabling services..."
if ! grep -q "btrfs-overlayfs" /etc/mkinitcpio.conf; then
    sudo sed -i "s/filesystems/filesystems btrfs-overlayfs/" /etc/mkinitcpio.conf
fi

sudo limine-mkinitcpio -P

{{ if eq .chezmoi.hostname "arch-surface" -}}
#echo "🔧 Forcing Timeout to 0 to fix freeze when my usb hubs are connected..."
#sudo sed -i 's/^#\?timeout:.*/timeout: 0/' /boot/limine.conf
{{ end -}}

sudo systemctl daemon-reload
sudo systemctl enable --now limine-snapper-sync.service
sudo limine-snapper-sync

echo "✅ Boot and Snapshot configuration SUCCESSFUL."

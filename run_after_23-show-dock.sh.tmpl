#!/usr/bin/env bash
set -euo pipefail

DOCK_DISABLED_FILE="$HOME/.config/ml4w/settings/dock-disabled"
DOCK_LAUNCHER="$HOME/.config/nwg-dock-hyprland/launch.sh"

rm -f "$DOCK_DISABLED_FILE"

if [[ -n "${WAYLAND_DISPLAY:-}" && -x "$DOCK_LAUNCHER" ]]; then
  nohup "$DOCK_LAUNCHER" >/dev/null 2>&1 &
fi
